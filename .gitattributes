###############################################################################
# Normalize text files
###############################################################################

* text=auto

###############################################################################
# C#
###############################################################################

*.cs text diff=csharp
*.csproj text
*.sln text
*.slnx text
*.props text
*.targets text

###############################################################################
# JSON
###############################################################################

*.json text

###############################################################################
# XML
###############################################################################

*.xml text

###############################################################################
# Markdown
###############################################################################

*.md text

###############################################################################
# JavaScript / TypeScript
###############################################################################

*.js text
*.jsx text
*.ts text
*.tsx text

###############################################################################
# CSS / HTML
###############################################################################

*.css text
*.scss text
*.html text

###############################################################################
# YAML
###############################################################################

*.yml text
*.yaml text

###############################################################################
# Shell Scripts
###############################################################################

*.sh text eol=lf

###############################################################################
# Windows Scripts
###############################################################################

*.bat text eol=crlf
*.cmd text eol=crlf

###############################################################################
# Docker
###############################################################################

Dockerfile text
*.dockerfile text

###############################################################################
# Images
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

###############################################################################
# Fonts
###############################################################################

*.woff binary
*.woff2 binary
*.ttf binary

###############################################################################
# PDF
###############################################################################

*.pdf binary